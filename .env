################################################################################
# CROSS-PLATFORM TEST CONFIGURATION
################################################################################

# Test Platform: mobile | web | cross-platform
TEST_PLATFORM=cross-platform

# Environment: dev | staging | prod
ENV=staging

# Browser for Web Tests: chrome | firefox | edge
BROWSER=chrome

################################################################################
# ANDROID CONFIGURATION (for Mobile & Cross-Platform Tests)
################################################################################

# Android SDK
ANDROID_HOME=C:\Users\talha\AppData\Local\Android\Sdk

# Android Device (single-device modes)
DEVICE_NAME=R58N84YW18Y
PLATFORM_VERSION=13
UDID=R58N84YW18Y
DRIVER_APP_PACKAGE=com.albaikdriver.staging
DRIVER_APP_ACTIVITY=com.albaikdriver.staging.MainActivity

# Dual-Mobile Mode: DISABLED (Commented out to run both apps sequentially on a single device)
# CUSTOMER_UDID=R58N84YW18Y
# DRIVER_UDID=emulator-5554
# DRIVER_APP_PACKAGE=com.albaikdriver.staging
# DRIVER_APP_ACTIVITY=com.albaikdriver.staging.MainActivity

# App (Play Store installed app)
# APP_PATH=/path/to/albaik.apk
APP_PATH=


APP_PACKAGE=com.albaik.customer.staging
APP_ACTIVITY=com.albaikapp.MainActivity

################################################################################
# WEB CONFIGURATION (for Web & Cross-Platform Tests)
################################################################################

# Web Admin Panel URL
# ADMIN_PANEL_URL=https://staging.ordering.albaikcloud.com/admin
# ADMIN_EMAIL=admin@albaik.com
# ADMIN_PASSWORD=your_password

