# Android SDK — path to your local Android SDK installation
ANDROID_HOME=C:\Users\<YOUR_USERNAME>\AppData\Local\Android\Sdk

# Android Device
DEVICE_NAME=emulator-5554           # or your physical device name from: adb devices
PLATFORM_VERSION=14.0               # Android version of your device
UDID=                               # Leave blank for emulator, fill for physical device

# App
APP_PATH=./apps/albaik.apk         # Leave blank if app is already installed from Play Store
APP_PACKAGE=com.albaik.app         # Get from: adb shell dumpsys window | grep mCurrentFocus
APP_ACTIVITY=.MainActivity          # Get from: adb shell dumpsys window | grep mCurrentFocus
